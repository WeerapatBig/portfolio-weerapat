# ────────────────────────────────────────────────────────────────
# ตัวอย่างค่า environment สำหรับตัวนับวิว (Upstash Redis)
#
# วิธีใช้:
#   - บน Netlify (production): ไม่ต้องใช้ไฟล์นี้ → ใส่ค่า 2 ตัวนี้ใน
#     Netlify dashboard → Site configuration → Environment variables
#   - ทดสอบบนเครื่อง (optional): คัดลอกไฟล์นี้เป็น ".env" แล้วเติมค่าจริง
#     จาก Upstash (database → REST API) จากนั้นรัน `netlify dev`
#
# ⚠️ ห้าม commit ไฟล์ ".env" จริง (ถูกใส่ใน .gitignore แล้ว)
# ────────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=https://your-db-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here
